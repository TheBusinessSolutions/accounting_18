#. module: account_invoice_custom_rounding
#: model:ir.model,name:account_invoice_custom_rounding.model_res_partner
msgid "Contact"
msgstr "Contacto"

#. module: account_invoice_custom_rounding
#: model:ir.model.fields,help:account_invoice_custom_rounding.field_res_partner__tax_calculation_rounding_method
#: model:ir.model.fields,help:account_invoice_custom_rounding.field_res_users__tax_calculation_rounding_method
msgid ""
"How total tax amount is computed in sale orders and invoices when this "
"contact is selected. If no value selected, the method defined in the company"
" is used."
msgstr ""
"Como se calcula el importe de los impuesto en los pedidos y facturas cuando "
"se usa este contacto. Si no se selecciona ningún valor, se usará el valor "
"por defecto de la compañía."

#. module: account_invoice_custom_rounding
#: model:ir.model.fields,help:account_invoice_custom_rounding.field_account_bank_statement_line__tax_calculation_rounding_method
#: model:ir.model.fields,help:account_invoice_custom_rounding.field_account_move__tax_calculation_rounding_method
#: model:ir.model.fields,help:account_invoice_custom_rounding.field_account_move_line__tax_calculation_rounding_method
msgid ""
"How total tax amount is computed. If no value selected, the method defined "
"in the company is used."
msgstr ""
"Como se calcula el import de los impuestos. Si no se selecciona un valor, se "
"usa el valor por defecto de la compañía."

