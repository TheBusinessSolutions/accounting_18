<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Odoo 19: res.groups requires a privilege_id pointing to res.groups.privilege.
             Reference: see odoo19-breaking-changes memory. -->
        <record id="module_category_finance_insights" model="ir.module.category">
            <field name="name">Finance Insights</field>
            <field name="description">Access to advanced finance dashboards and reports</field>
            <field name="sequence">25</field>
        </record>

        <record id="privilege_finance_insights" model="res.groups.privilege">
            <field name="name">Finance Insights</field>
            <field name="category_id" ref="module_category_finance_insights"/>
            <field name="sequence">10</field>
            <field name="description">Access to the Finance Insights dashboards and reports.</field>
        </record>

        <record id="group_finance_insights_user" model="res.groups">
            <field name="name">User: View Dashboards &amp; Reports</field>
            <field name="privilege_id" ref="privilege_finance_insights"/>
            <field name="implied_ids" eval="[(4, ref('account.group_account_invoice'))]"/>
        </record>

        <record id="group_finance_insights_manager" model="res.groups">
            <field name="name">Manager: Full Access</field>
            <field name="privilege_id" ref="privilege_finance_insights"/>
            <field name="implied_ids" eval="[
                (4, ref('group_finance_insights_user')),
                (4, ref('account.group_account_manager')),
            ]"/>
            <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        </record>

    </data>
</odoo>
