<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="mn_finance_insights.TaxReconciliation">
        <div class="o_fi_dashboard">
            <div class="o_fi_header">
                <div class="o_fi_title"><h2><i class="fa fa-balance-scale-right me-2"/>Tax Reconciliation Audit</h2>
                    <small class="text-muted" t-if="state.data" t-esc="state.data.company_name"/></div>
                <div class="o_fi_filters">
                    <label>From</label><input type="date" t-att-value="state.options.date_from" t-on-change="(ev) => this.onFilterChange('date_from', ev)"/>
                    <label>To</label><input type="date" t-att-value="state.options.date_to" t-on-change="(ev) => this.onFilterChange('date_to', ev)"/>
                </div>
            </div>
            <div t-if="state.loading" class="o_fi_loading"><i class="fa fa-spinner fa-spin fa-2x"/></div>
            <t t-if="!state.loading and state.data">
                <div class="o_fi_kpi_grid">
                    <div class="o_fi_kpi_card kpi-net"><div class="o_fi_kpi_label">Total Net VAT Due</div>
                        <div class="o_fi_kpi_value" t-esc="formatAmount(state.data.total_due)"/></div>
                </div>
                <div class="o_fi_chart_card">
                    <h5>Per tax breakdown</h5>
                    <table class="o_fi_table">
                        <thead><tr><th>Tax</th>
                            <th class="num">Output Collected</th><th class="num">Out Refunds</th>
                            <th class="num">Input Paid</th><th class="num">In Refunds</th>
                            <th class="num">Net Collected</th><th class="num">Net Paid</th>
                            <th class="num">Net Due</th></tr></thead>
                        <tbody>
                            <t t-foreach="state.data.rows" t-as="r" t-key="r.id">
                                <tr><td><strong t-esc="r.name"/></td>
                                    <td class="num text-success" t-esc="formatAmount(r.out_collected)"/>
                                    <td class="num text-danger" t-esc="formatAmount(r.out_refund)"/>
                                    <td class="num text-success" t-esc="formatAmount(r.in_paid)"/>
                                    <td class="num text-danger" t-esc="formatAmount(r.in_refund)"/>
                                    <td class="num" t-esc="formatAmount(r.net_collected)"/>
                                    <td class="num" t-esc="formatAmount(r.net_paid)"/>
                                    <td class="num"><strong t-esc="formatAmount(r.net_due)"/></td></tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </div>
    </t>
</templates>
