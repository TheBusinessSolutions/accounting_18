<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="mn_finance_insights.DailySales">
        <div class="o_fi_dashboard" t-ref="root">
            <div class="o_fi_header">
                <div class="o_fi_title"><h2><i class="fa fa-bolt me-2"/>Daily Sales Snapshot</h2>
                    <small class="text-muted" t-if="state.data" t-esc="state.data.company_name"/></div>
                <div class="o_fi_filters">
                    <label>As of</label>
                    <input type="date" t-att-value="state.options.as_of" t-on-change="(ev) => this.onFilterChange('as_of', ev)"/>
                </div>
            </div>
            <div t-if="state.loading" class="o_fi_loading"><i class="fa fa-spinner fa-spin fa-2x"/></div>
            <t t-if="!state.loading and state.data">
                <div class="o_fi_kpi_grid">
                    <div class="o_fi_kpi_card kpi-revenue"><div class="o_fi_kpi_label">Today</div>
                        <div class="o_fi_kpi_value" t-esc="formatAmount(state.data.today)"/></div>
                    <div class="o_fi_kpi_card kpi-cash"><div class="o_fi_kpi_label">Week-to-date</div>
                        <div class="o_fi_kpi_value" t-esc="formatAmount(state.data.wtd)"/></div>
                    <div class="o_fi_kpi_card kpi-net"><div class="o_fi_kpi_label">Month-to-date</div>
                        <div class="o_fi_kpi_value" t-esc="formatAmount(state.data.mtd)"/></div>
                    <div class="o_fi_kpi_card kpi-gm"><div class="o_fi_kpi_label">YTD &#183; vs last year</div>
                        <div class="o_fi_kpi_value" t-esc="formatAmount(state.data.ytd)"/>
                        <div class="o_fi_kpi_delta" t-att-class="state.data.ytd_delta_pct &gt;= 0 ? 'text-success' : 'text-danger'">
                            <t t-esc="(state.data.ytd_delta_pct &gt;= 0 ? '↑ ' : '↓ ') + Math.abs(state.data.ytd_delta_pct) + '% vs last year'"/>
                        </div>
                    </div>
                </div>
                <div class="o_fi_chart_card">
                    <h5>Last 30 days</h5>
                    <div class="o_fi_chart_canvas" style="height:280px;"><canvas data-chart="daily"/></div>
                </div>
            </t>
        </div>
    </t>
</templates>
