<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="mn_finance_insights.CashEfficiency">
        <div class="o_fi_dashboard" t-ref="root">
            <div class="o_fi_header">
                <div class="o_fi_title"><h2><i class="fa fa-tachometer-alt me-2"/>Cash Conversion Efficiency</h2>
                    <small class="text-muted" t-if="state.data" t-esc="state.data.company_name"/></div>
                <div class="o_fi_filters">
                    <label>As of</label><input type="date" t-att-value="state.options.as_of" t-on-change="(ev) => this.onFilterChange('as_of', ev)"/>
                </div>
            </div>
            <div t-if="state.loading" class="o_fi_loading"><i class="fa fa-spinner fa-spin fa-2x"/></div>
            <t t-if="!state.loading and state.data">
                <div class="o_fi_kpi_grid">
                    <div class="o_fi_kpi_card kpi-net"><div class="o_fi_kpi_label">12-Month Avg Ratio</div>
                        <div class="o_fi_kpi_value">
                            <span class="o_fi_heat" t-att-class="ratioClass(state.data.avg_ratio)" t-esc="state.data.avg_ratio + 'x'"/>
                        </div>
                    </div>
                </div>
                <div class="o_fi_chart_card"><h5>Cash change vs net income &amp; ratio</h5>
                    <div class="o_fi_chart_canvas" style="height:340px;"><canvas data-chart="ce"/></div>
                </div>
            </t>
        </div>
    </t>
</templates>
