<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="mn_finance_insights.CustomerChurn">
        <div class="o_fi_dashboard">
            <div class="o_fi_header">
                <div class="o_fi_title"><h2><i class="fa fa-user-times me-2"/>Customer Churn Risk</h2>
                    <small class="text-muted" t-if="state.data" t-esc="state.data.company_name"/></div>
                <div class="o_fi_filters">
                    <label>Inactive &gt;</label>
                    <input type="number" t-att-value="state.options.inactive_days" t-on-change="(ev) => this.onFilterChange('inactive_days', ev)" style="width:90px;"/>
                    <span class="text-muted">days</span>
                </div>
            </div>
            <div t-if="state.loading" class="o_fi_loading"><i class="fa fa-spinner fa-spin fa-2x"/></div>
            <t t-if="!state.loading and state.data">
                <div class="o_fi_kpi_grid">
                    <div class="o_fi_kpi_card kpi-ar"><div class="o_fi_kpi_label">At-Risk Customers</div>
                        <div class="o_fi_kpi_value" t-esc="state.data.count"/></div>
                    <div class="o_fi_kpi_card kpi-expenses"><div class="o_fi_kpi_label">Critical (likely lost)</div>
                        <div class="o_fi_kpi_value" t-esc="state.data.critical_count"/></div>
                    <div class="o_fi_kpi_card kpi-net"><div class="o_fi_kpi_label">LTV At Risk</div>
                        <div class="o_fi_kpi_value" t-esc="formatAmount(state.data.ltv_at_risk)"/></div>
                </div>
                <div class="o_fi_chart_card">
                    <h5>Customers sorted by historical LTV</h5>
                    <table class="o_fi_table">
                        <thead><tr><th>Customer</th><th>Last invoice</th><th class="num">Days inactive</th><th class="num">Historical LTV</th></tr></thead>
                        <tbody>
                            <t t-foreach="state.data.rows" t-as="r" t-key="r.id">
                                <tr><td><strong t-esc="r.name"/></td>
                                    <td t-esc="r.last_invoice"/>
                                    <td class="num"><span class="o_fi_heat" t-att-class="'heat-' + r.severity" t-esc="r.days_inactive + ' d'"/></td>
                                    <td class="num"><strong t-esc="formatAmount(r.ltv)"/></td></tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </div>
    </t>
</templates>
