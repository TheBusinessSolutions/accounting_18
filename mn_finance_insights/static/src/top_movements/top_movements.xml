<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="mn_finance_insights.TopMovements">
        <div class="o_fi_dashboard">
            <div class="o_fi_header">
                <div class="o_fi_title"><h2><i class="fa fa-arrows-alt-v me-2"/>Top Account Movements</h2>
                    <small class="text-muted" t-if="state.data" t-esc="state.data.company_name"/></div>
                <div class="o_fi_filters">
                    <label>From</label><input type="date" t-att-value="state.options.date_from" t-on-change="(ev) => this.onFilterChange('date_from', ev)"/>
                    <label>To</label><input type="date" t-att-value="state.options.date_to" t-on-change="(ev) => this.onFilterChange('date_to', ev)"/>
                </div>
            </div>
            <div t-if="state.loading" class="o_fi_loading"><i class="fa fa-spinner fa-spin fa-2x"/></div>
            <div t-if="!state.loading and state.data" class="o_fi_chart_card">
                <h5>Top 30 line items by absolute amount</h5>
                <table class="o_fi_table">
                    <thead><tr><th>Date</th><th>Move</th><th>Account</th><th>Partner</th>
                        <th class="num">Debit</th><th class="num">Credit</th><th class="num">Amount</th></tr></thead>
                    <tbody>
                        <t t-foreach="state.data.rows" t-as="r" t-key="r.id">
                            <tr><td t-esc="r.date"/>
                                <td><strong t-esc="r.move"/></td>
                                <td t-esc="r.account"/>
                                <td t-esc="r.partner"/>
                                <td class="num text-success" t-esc="r.debit ? formatAmount(r.debit) : '—'"/>
                                <td class="num text-danger" t-esc="r.credit ? formatAmount(r.credit) : '—'"/>
                                <td class="num"><strong t-esc="formatAmount(r.amount)"/></td></tr>
                        </t>
                    </tbody>
                </table>
            </div>
        </div>
    </t>
</templates>
