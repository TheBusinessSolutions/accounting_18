<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="mn_finance_insights.RecurringRevenue">
        <div class="o_fi_dashboard" t-ref="root">
            <div class="o_fi_header">
                <div class="o_fi_title"><h2><i class="fa fa-sync-alt me-2"/>Recurring Revenue Tracker</h2>
                    <small class="text-muted" t-if="state.data" t-esc="state.data.company_name"/></div>
                <div class="o_fi_filters">
                    <label>As of</label><input type="date" t-att-value="state.options.as_of" t-on-change="(ev) => this.onFilterChange('as_of', ev)"/>
                </div>
            </div>
            <div t-if="state.loading" class="o_fi_loading"><i class="fa fa-spinner fa-spin fa-2x"/></div>
            <t t-if="!state.loading and state.data">
                <div class="o_fi_kpi_grid">
                    <div class="o_fi_kpi_card kpi-revenue"><div class="o_fi_kpi_label">Last 3 mo Revenue</div>
                        <div class="o_fi_kpi_value" t-esc="formatAmount(state.data.last3_total)"/></div>
                    <div class="o_fi_kpi_card kpi-net"><div class="o_fi_kpi_label">Last 3 mo Repeat</div>
                        <div class="o_fi_kpi_value" t-esc="formatAmount(state.data.last3_repeat)"/></div>
                    <div class="o_fi_kpi_card kpi-gm"><div class="o_fi_kpi_label">Repeat %</div>
                        <div class="o_fi_kpi_value" t-esc="state.data.last3_pct + '%'"/></div>
                </div>
                <div class="o_fi_chart_card"><h5>Monthly new vs repeat revenue</h5>
                    <div class="o_fi_chart_canvas" style="height:340px;"><canvas data-chart="rr"/></div>
                </div>
            </t>
        </div>
    </t>
</templates>
