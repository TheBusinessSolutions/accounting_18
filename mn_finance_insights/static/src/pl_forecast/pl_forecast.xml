<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="mn_finance_insights.PLForecast">
        <div class="o_fi_dashboard" t-ref="root">
            <div class="o_fi_header">
                <div class="o_fi_title"><h2><i class="fa fa-chart-line me-2"/>P&amp;L Forecast (3-Month Projection)</h2>
                    <small class="text-muted" t-if="state.data" t-esc="state.data.company_name"/></div>
                <div class="o_fi_filters">
                    <label>As of</label><input type="date" t-att-value="state.options.as_of" t-on-change="(ev) => this.onFilterChange('as_of', ev)"/>
                </div>
            </div>
            <div t-if="state.loading" class="o_fi_loading"><i class="fa fa-spinner fa-spin fa-2x"/></div>
            <t t-if="!state.loading and state.data">
                <div class="o_fi_kpi_grid">
                    <div class="o_fi_kpi_card kpi-net"><div class="o_fi_kpi_label">3-Month Forecast Net</div>
                        <div class="o_fi_kpi_value" t-esc="formatAmount(state.data.total_forecast_net)"/></div>
                    <div class="o_fi_kpi_card kpi-cash"><div class="o_fi_kpi_label">Avg Actual Monthly Net</div>
                        <div class="o_fi_kpi_value" t-esc="formatAmount(state.data.avg_net_actual)"/></div>
                </div>
                <div class="o_fi_chart_card"><h5>6 months actual + 3 months projection (linear regression)</h5>
                    <div class="o_fi_chart_canvas" style="height:340px;"><canvas data-chart="plf"/></div>
                </div>
            </t>
        </div>
    </t>
</templates>
