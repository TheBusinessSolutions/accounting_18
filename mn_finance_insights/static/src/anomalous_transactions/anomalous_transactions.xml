<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="mn_finance_insights.AnomalousTransactions">
        <div class="o_fi_dashboard">
            <div class="o_fi_header">
                <div class="o_fi_title"><h2><i class="fa fa-radiation me-2"/>Anomalous Transactions</h2>
                    <small class="text-muted" t-if="state.data">
                        <t t-esc="state.data.company_name"/> &#183;
                        <strong t-esc="state.data.count"/> outliers found (z ≥ <t t-esc="state.data.z_threshold"/>)
                    </small>
                </div>
                <div class="o_fi_filters">
                    <label>From</label><input type="date" t-att-value="state.options.date_from" t-on-change="(ev) => this.onFilterChange('date_from', ev)"/>
                    <label>To</label><input type="date" t-att-value="state.options.date_to" t-on-change="(ev) => this.onFilterChange('date_to', ev)"/>
                    <label>Z threshold</label>
                    <input type="number" step="0.1" t-att-value="state.options.z_threshold" t-on-change="(ev) => this.onFilterChange('z_threshold', ev)" style="width:80px;"/>
                </div>
            </div>
            <div t-if="state.loading" class="o_fi_loading"><i class="fa fa-spinner fa-spin fa-2x"/></div>
            <div t-if="!state.loading and state.data" class="o_fi_chart_card">
                <h5>Outlier line items (sorted by z-score)</h5>
                <table class="o_fi_table">
                    <thead><tr><th>Date</th><th>Move</th><th>Account</th><th>Partner</th>
                        <th class="num">Amount</th><th class="num">Expected</th><th class="num">Z-score</th></tr></thead>
                    <tbody>
                        <t t-foreach="state.data.rows" t-as="r" t-key="r.id">
                            <tr><td t-esc="r.date"/>
                                <td><strong t-esc="r.move"/></td>
                                <td t-esc="r.account"/>
                                <td t-esc="r.partner"/>
                                <td class="num"><strong t-esc="formatAmount(r.amount)"/></td>
                                <td class="num text-muted" t-esc="formatAmount(r.expected)"/>
                                <td class="num">
                                    <span class="o_fi_heat" t-att-class="r.z_score &gt; 4 ? 'heat-bad' : 'heat-ok'" t-esc="r.z_score + 'σ'"/>
                                </td></tr>
                        </t>
                    </tbody>
                </table>
            </div>
        </div>
    </t>
</templates>
