<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="mn_finance_insights.ExpenseAnalytics">
        <div class="o_fi_dashboard" t-ref="root">
            <div class="o_fi_header">
                <div class="o_fi_title">
                    <h2><i class="fa fa-money-bill-wave me-2"/>Expense Analytics</h2>
                    <small class="text-muted" t-if="state.data" t-esc="state.data.company_name"/>
                </div>
                <div class="o_fi_filters">
                    <label>From</label>
                    <input type="date" t-att-value="state.options.date_from"
                           t-on-change="(ev) => this.onFilterChange('date_from', ev)"/>
                    <label>To</label>
                    <input type="date" t-att-value="state.options.date_to"
                           t-on-change="(ev) => this.onFilterChange('date_to', ev)"/>
                </div>
            </div>

            <div t-if="state.loading" class="o_fi_loading">
                <i class="fa fa-spinner fa-spin fa-2x"/><div class="mt-2">Loading…</div>
            </div>

            <t t-if="!state.loading and state.data">
                <div class="o_fi_kpi_grid">
                    <t t-foreach="[
                        ['total_expense', 'Total Expense', 'fa-arrow-down', 'kpi-expenses', true],
                        ['bill_count', 'Bills', 'fa-file-invoice', 'kpi-ap', false],
                        ['refund_count', 'Refunds', 'fa-undo', 'kpi-net', false],
                        ['avg_bill', 'Avg Bill', 'fa-calculator', 'kpi-cash', true],
                        ['unpaid', 'Unpaid Bills', 'fa-exclamation-triangle', 'kpi-ar', true],
                    ]" t-as="card" t-key="card[0]">
                        <div class="o_fi_kpi_card" t-att-class="card[3]">
                            <div class="o_fi_kpi_icon"><i class="fa" t-att-class="card[2]"/></div>
                            <div class="o_fi_kpi_body">
                                <div class="o_fi_kpi_label" t-esc="card[1]"/>
                                <div class="o_fi_kpi_value">
                                    <t t-if="card[4]" t-esc="formatAmount(state.data.kpis[card[0]])"/>
                                    <t t-else="" t-esc="state.data.kpis[card[0]]"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>

                <div class="o_fi_charts_grid">
                    <div class="o_fi_chart_card o_fi_chart_wide">
                        <h5>Monthly expenses</h5>
                        <div class="o_fi_chart_canvas" style="height:260px;">
                            <canvas data-chart="trend"/>
                        </div>
                    </div>
                    <div class="o_fi_chart_card o_fi_chart_wide">
                        <h5>By account</h5>
                        <div class="o_fi_chart_canvas" style="height:340px;">
                            <canvas data-chart="accounts"/>
                        </div>
                    </div>
                </div>

                <div class="o_fi_chart_card" style="margin-top:14px;">
                    <h5>Top vendors</h5>
                    <table class="o_fi_table">
                        <thead><tr><th>Vendor</th><th class="num">Total spent</th></tr></thead>
                        <tbody>
                            <t t-foreach="state.data.top_vendors" t-as="v" t-key="v.id">
                                <tr><td t-esc="v.name"/><td class="num" t-esc="formatAmount(v.amount)"/></tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </div>
    </t>

</templates>
